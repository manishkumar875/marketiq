# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is already covered by .gitignore.

# Required — from Supabase Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# Required — server-only, NEVER expose this in the browser or commit it.
# Used only for writing to the audit_log table (see lib/supabase/admin.ts).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional — for email notifications when a lead or research request
# comes in. If left unset, the site works fine and simply skips sending
# notification emails.
RESEND_API_KEY=your-resend-api-key-here
NOTIFICATION_EMAIL=team@prime-eyeresearch.com
